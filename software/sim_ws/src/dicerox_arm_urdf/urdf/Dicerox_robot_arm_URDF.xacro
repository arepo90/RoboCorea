<robot name="Dicerox_robot_arm_URDF">

  <link name="world_link" />

  <!-- Rotate the CAD-exported base so the robot stands upright in RViz/MoveIt. -->
  <joint name="world_link_to_base_link" type="fixed">
    <origin xyz="0 0 0" rpy="3.141592653589793 0 0" />
    <parent link="world_link" />
    <child link="base_link" />
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="-9.49825873871185E-05 -1.04297722111363E-06 0.0144742771636322" rpy="0 0 0" />
      <mass value="0.616927576087879" />
      <inertia ixx="0.00235120961653514" ixy="1.48592051070372E-08" ixz="1.72093144714663E-07" iyy="0.000752293306588767" iyz="8.93709469162573E-10" izz="0.0030503193907466" />
    </inertial>
    <!-- Visual and collision geometry intentionally omitted:
         the chassis URDF (dicerox_urdf_v1) provides the complete base_link mesh.
         Keeping geometry here would cause duplicate/overlapping models in RViz. -->
  </link>
  <link name="Link1">
    <inertial>
      <origin xyz="-1.5987E-06 0.024748 -0.061373" rpy="0 0 0" />
      <mass value="0.40272" />
      <inertia ixx="0.00020115" ixy="8.9742E-10" ixz="1.4855E-08" iyy="0.00029101" iyz="5.2612E-06" izz="0.00020797" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://dicerox_arm_urdf/meshes/visual/Link1.STL" />
      </geometry>
      <material name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://dicerox_arm_urdf/meshes/collision/Link1.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="Joint1" type="revolute">
    <origin xyz="0 0 -0.02135" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="Link1" />
    <axis xyz="0 0 1" />
    <limit lower="-1.5708" upper="1.5708" effort="1000" velocity="1000" />
    <dynamics damping="0.1" friction="0.1" />
  </joint>
  <link name="Link2">
    <inertial>
      <origin xyz="-0.243045429859638 -0.0135631154060198 0.0109133250229265" rpy="0 0 0" />
